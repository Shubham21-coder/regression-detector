# Local mode (LM Studio)
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=qwen2.5-3b-instruct

# Cloud mode (Groq — for hosted demo)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Which backend to use: "local" or "groq"
LLM_BACKEND=local

# For demo mode (limits to 10 cases for speed)
DEMO_MODE=false
DEMO_CASE_LIMIT=10
